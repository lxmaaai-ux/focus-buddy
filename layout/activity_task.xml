<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Tasks"
        android:textColor="@color/accent_yellow"
        android:textSize="22sp"
        android:textStyle="bold"/>

    <!-- TASK INPUT -->
    <EditText
        android:id="@+id/taskInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Task"
        android:textColor="@color/white"
        android:textColorHint="@color/hint"
        android:background="@drawable/input_bg"
        android:padding="12dp"
        android:layout_marginTop="10dp"/>

    <!-- SUBTASK CONTAINER -->
    <LinearLayout
        android:id="@+id/subtaskContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"/>

    <!-- ADD SUBTOPIC BUTTON -->
    <Button
        android:id="@+id/addSubtaskBtn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="+ ADD SUBTOPIC"
        android:textStyle="bold"
        android:background="@drawable/btn_glow"
        android:textColor="@color/bg_dark"
        android:layout_marginTop="8dp"/>

    <!-- DONE BUTTON (IMPORTANT) -->
    <Button
        android:id="@+id/addTimeBtn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="DONE"
        android:textStyle="bold"
        android:background="@drawable/btn_glow"
        android:textColor="@color/bg_dark"
        android:layout_marginTop="10dp"/>

    <!-- TASK LIST -->
    <ListView
        android:id="@+id/taskList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/accent_yellow"
        android:dividerHeight="1dp"
        android:layout_marginTop="10dp"/>

</LinearLayout>