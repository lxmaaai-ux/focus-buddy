<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/bg_dark">

    <EditText
        android:id="@+id/planInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter your daily routine..."
        android:textColor="@color/white"
        android:textColorHint="@color/hint"
        android:background="@drawable/input_bg"
        android:padding="14dp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/generateBtn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="GENERATE PLAN"
        android:textStyle="bold"
        android:textColor="@color/bg_dark"
        android:background="@drawable/btn_glow"
        android:layout_marginBottom="20dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_dark"
        android:padding="16dp">

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your plan will appear here..."
            android:textColor="@color/white"/>
    </ScrollView>

</LinearLayout>